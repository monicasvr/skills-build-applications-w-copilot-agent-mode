# OctoFit Tracker Frontend Environment Variables
# Copy this file to .env.local and update values as needed

# REQUIRED: Codespaces Name
# Set this to your GitHub Codespaces name to use the Codespaces backend URL
# For example: if your Codespaces URL is https://example-monicasvr-xxxxx.github.dev
# then VITE_CODESPACE_NAME=example-monicasvr-xxxxx
#
# If not set, the application will fall back to http://localhost:8000
VITE_CODESPACE_NAME=

# Optional: Backend API Port (usually 8000 for Codespaces and local)
# VITE_API_PORT=8000
